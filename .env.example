# ════════════════════════════════════════════════════════════
#  NOPRUT CLI v2 — Configuration
#  Made in Thailand
# ════════════════════════════════════════════════════════════

# Base URL for the API backend (OpenAI-compatible)
NOPRUT_API_BASE_URL=https://www.noprut-ai.dev

# Your API key.
NOPRUT_API_KEY=your_api_key_here

# Default model id (provider/model). Optional.
NOPRUT_MODEL_ID=deepseek/deepseek-v4-flash

# Optional: max output tokens per response (default 16384)
# NOPRUT_MAX_TOKENS=16384

# Optional: auto-approve safe read-only shell commands (true/false, default true)
# NOPRUT_AUTO_APPROVE_READONLY=true
